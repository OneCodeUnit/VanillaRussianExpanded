<?xml version="1.0" encoding="utf-8"?>
<LanguageData>
  <!-- EN: thump retrofit -->
  <VWE_ThumpRetrofit.label>ударная модернизация</VWE_ThumpRetrofit.label>
  <!-- EN: This weapon incorporates reverse-engineered mechanoid technology to fire heavy, blunt-force energy slugs that devastate structures and armor at the cost of range. -->
  <VWE_ThumpRetrofit.description>Оружие улучшено с использованием воссозданной технологии механоидов, для стрельбы тяжёлыми ударными энергетическими снарядами, сокрушающими укрепления и броню, но имеющими низкую дальность.</VWE_ThumpRetrofit.description>
  <!-- EN: thumping -->
  <VWE_ThumpRetrofit.traitAdjectives.0>громящий</VWE_ThumpRetrofit.traitAdjectives.0>
  <!-- EN: siege -->
  <VWE_ThumpRetrofit.traitAdjectives.1>осадный</VWE_ThumpRetrofit.traitAdjectives.1>
  <!-- EN: kinetic -->
  <VWE_ThumpRetrofit.traitAdjectives.2>кинетический</VWE_ThumpRetrofit.traitAdjectives.2>
  <!-- EN: heavy -->
  <VWE_ThumpRetrofit.traitAdjectives.3>тяжёлый</VWE_ThumpRetrofit.traitAdjectives.3>
  <!-- EN: crushing -->
  <VWE_ThumpRetrofit.traitAdjectives.4>сокрушительный</VWE_ThumpRetrofit.traitAdjectives.4>

  <!-- EN: acid-injector flechettes -->
  <VWE_AcidInjectorFlechettes.label>кислотные иглы</VWE_AcidInjectorFlechettes.label>
  <!-- EN: This weapon has been re-barreled to fire fin-stabilized acid-injector flechettes. These rounds cause horrific internal dissolution in organic targets but are useless against mechanoids. -->
  <VWE_AcidInjectorFlechettes.description>Ствол оружия переоборудован для стрельбы игольчатыми патронами со стабилизированными оперением и кислотными инжекторами. Эти снаряды вызывают ужасающий распад внутренних органов у органических целей, но бесполезны против механоидов.</VWE_AcidInjectorFlechettes.description>
  <!-- EN: fletcher -->
  <VWE_AcidInjectorFlechettes.traitAdjectives.0>игольчатый</VWE_AcidInjectorFlechettes.traitAdjectives.0>
  <!-- EN: acid-needle -->
  <VWE_AcidInjectorFlechettes.traitAdjectives.1>кислотная игла</VWE_AcidInjectorFlechettes.traitAdjectives.1>
  <!-- EN: injecting -->
  <VWE_AcidInjectorFlechettes.traitAdjectives.2>впрыскивающий</VWE_AcidInjectorFlechettes.traitAdjectives.2>
  <!-- EN: dissolving -->
  <VWE_AcidInjectorFlechettes.traitAdjectives.3>растворяющий</VWE_AcidInjectorFlechettes.traitAdjectives.3>

  <!-- EN: deserter markings -->
  <VWE_DeserterMarkings.label>метки дезертира</VWE_DeserterMarkings.label>
  <!-- EN: This weapon bears defaced Imperial crests; equipping it in the presence of Imperial caravans or visitors will be recognized as treason, causing an immediate and severe drop in relations. -->
  <VWE_DeserterMarkings.description>На оружие нанесены изуродованные имперские гербы. Появившись с ним рядом с имперскими торговыми караванами или гостями, вас сочтут предателем. Это вызовет немедленное и резкое ухудшение отношений.</VWE_DeserterMarkings.description>
  <!-- EN: traitor -->
  <VWE_DeserterMarkings.traitAdjectives.0>предательский</VWE_DeserterMarkings.traitAdjectives.0>
  <!-- EN: deserter -->
  <VWE_DeserterMarkings.traitAdjectives.1>дезертирский</VWE_DeserterMarkings.traitAdjectives.1>
  <!-- EN: stolen -->
  <VWE_DeserterMarkings.traitAdjectives.2>краденый</VWE_DeserterMarkings.traitAdjectives.2>
  <!-- EN: defaced -->
  <VWE_DeserterMarkings.traitAdjectives.3>изуродованный</VWE_DeserterMarkings.traitAdjectives.3>
  <!-- EN: illicit -->
  <VWE_DeserterMarkings.traitAdjectives.4>незаконный</VWE_DeserterMarkings.traitAdjectives.4>

  <!-- EN: high-angle draw -->
  <VWE_HighAngleDraw.label>стрельба навесом</VWE_HighAngleDraw.label>
  <!-- EN: This weapon is strung for extreme parabolic arcing, allowing arrows to be lobbed over walls and obstacles to hit unseen targets, though it is impossible to aim precisely. -->
  <VWE_HighAngleDraw.description>Тетива лука выставлена для экстремальной параболической дуги, что позволяет перекидывать стрелы через стены и препятствия для поражения целей вне поля зрения. Прицельная стрельба при этом невозможна.</VWE_HighAngleDraw.description>
  <!-- EN: arcing -->
  <VWE_HighAngleDraw.traitAdjectives.0>навесной</VWE_HighAngleDraw.traitAdjectives.0>
  <!-- EN: parabolic -->
  <VWE_HighAngleDraw.traitAdjectives.1>параболический</VWE_HighAngleDraw.traitAdjectives.1>
  <!-- EN: lobbing -->
  <VWE_HighAngleDraw.traitAdjectives.2>перекидной</VWE_HighAngleDraw.traitAdjectives.2>
  <!-- EN: indirect -->
  <VWE_HighAngleDraw.traitAdjectives.3>непрямой</VWE_HighAngleDraw.traitAdjectives.3>
  <!-- EN: siege -->
  <VWE_HighAngleDraw.traitAdjectives.4>осадный</VWE_HighAngleDraw.traitAdjectives.4>

  <!-- EN: lucky shots -->
  <VWE_LuckyShots.label>удачные выстрелы</VWE_LuckyShots.label>
  <!-- EN: This weapon's action is tuned for occasional moments of perfect alignment, granting a chance for shots to bypass defenses and inflict significant bonus damage. -->
  <VWE_LuckyShots.description>Механизм оружия настроен на редкие моменты идеального совмещения. Таким образом, есть шанс, что выстрел обойдёт защиту и нанесёт значительный дополнительный урон.</VWE_LuckyShots.description>
  <!-- EN: critical -->
  <VWE_LuckyShots.traitAdjectives.0>критический</VWE_LuckyShots.traitAdjectives.0>
  <!-- EN: vicious -->
  <VWE_LuckyShots.traitAdjectives.1>жестокий</VWE_LuckyShots.traitAdjectives.1>
  <!-- EN: deadly -->
  <VWE_LuckyShots.traitAdjectives.2>смертоносный</VWE_LuckyShots.traitAdjectives.2>
  <!-- EN: tuned -->
  <VWE_LuckyShots.traitAdjectives.3>настроенный</VWE_LuckyShots.traitAdjectives.3>
  <!-- EN: lucky -->
  <VWE_LuckyShots.traitAdjectives.4>удачный</VWE_LuckyShots.traitAdjectives.4>

  <!-- EN: makeshift -->
  <VWE_MakeshiftTrait.label>самоделка</VWE_MakeshiftTrait.label>
  <!-- EN: This weapon is cobbled together from mismatched parts with a faulty sear mechanism. It is wildly unpredictable; sometimes it fails to fire entirely, while other times it accidentally discharges a double-length burst. -->
  <VWE_MakeshiftTrait.description>Оружие наспех собрано из несовместимых деталей с неисправным спусковым механизмом. Абсолютно непредсказуемо: иногда вовсе не стреляет, а иногда случайно выдаёт двойную очередь.</VWE_MakeshiftTrait.description>
  <!-- EN: makeshift -->
  <VWE_MakeshiftTrait.traitAdjectives.0>самодельный</VWE_MakeshiftTrait.traitAdjectives.0>
  <!-- EN: cobbled -->
  <VWE_MakeshiftTrait.traitAdjectives.1>наспех склёпанный</VWE_MakeshiftTrait.traitAdjectives.1>
  <!-- EN: jury-rigged -->
  <VWE_MakeshiftTrait.traitAdjectives.2>кое-как собранный</VWE_MakeshiftTrait.traitAdjectives.2>
  <!-- EN: scrap -->
  <VWE_MakeshiftTrait.traitAdjectives.3>утильный</VWE_MakeshiftTrait.traitAdjectives.3>
  <!-- EN: unpredictable -->
  <VWE_MakeshiftTrait.traitAdjectives.4>непредсказуемый</VWE_MakeshiftTrait.traitAdjectives.4>

  <!-- EN: ancient -->
  <VWE_AncientTrait.label>древнее</VWE_AncientTrait.label>
  <!-- EN: This weapon is a relic from a bygone era, its internal stress fractures held together by mere luck. It functions normally for a limited time, but after a set number of shots, the mechanism will shatter completely and the weapon will be destroyed. -->
  <VWE_AncientTrait.description>Это оружие является реликтом ушедшей эпохи, который держится на честном слове. Какое-то время им можно пользоваться, но после определённого числа выстрелов механизм полностью рассыпется и оружие будет уничтожено.</VWE_AncientTrait.description>
  <!-- EN: ancient -->
  <VWE_AncientTrait.traitAdjectives.0>древний</VWE_AncientTrait.traitAdjectives.0>
  <!-- EN: relic -->
  <VWE_AncientTrait.traitAdjectives.1>реликтовый</VWE_AncientTrait.traitAdjectives.1>
  <!-- EN: fragile -->
  <VWE_AncientTrait.traitAdjectives.2>хрупкий</VWE_AncientTrait.traitAdjectives.2>
  <!-- EN: crumbling -->
  <VWE_AncientTrait.traitAdjectives.3>рассыпающийся</VWE_AncientTrait.traitAdjectives.3>
  <!-- EN: finite -->
  <VWE_AncientTrait.traitAdjectives.4>конечный</VWE_AncientTrait.traitAdjectives.4>

  <!-- EN: crypto rounds -->
  <VWE_CryptoRounds.label>криптопатроны</VWE_CryptoRounds.label>
  <!-- EN: This weapon fires rounds coated in active cryptoparticles that induce a rapid stasis-freeze effect on impact. -->
  <VWE_CryptoRounds.description>Оружие стреляет снарядами, покрытыми активными крипточастицами, которые при попадании вызывают быстрый эффект криозаморозки.</VWE_CryptoRounds.description>
  <!-- EN: crypto -->
  <VWE_CryptoRounds.traitAdjectives.0>крипто</VWE_CryptoRounds.traitAdjectives.0>
  <!-- EN: stasis -->
  <VWE_CryptoRounds.traitAdjectives.1>стазисный</VWE_CryptoRounds.traitAdjectives.1>
  <!-- EN: freezing -->
  <VWE_CryptoRounds.traitAdjectives.2>замораживающий</VWE_CryptoRounds.traitAdjectives.2>
  <!-- EN: preserving -->
  <VWE_CryptoRounds.traitAdjectives.3>консервирующий</VWE_CryptoRounds.traitAdjectives.3>
  <!-- EN: absolute -->
  <VWE_CryptoRounds.traitAdjectives.4>абсолютный</VWE_CryptoRounds.traitAdjectives.4>

  <!-- EN: void inscriptions -->
  <VWE_VoidInscriptions.label>символы Пустоты</VWE_VoidInscriptions.label>
  <!-- EN: This weapon is etched with shifting, non-euclidean glyphs that whisper to the wielder, continually draining their mental stability while equipped. -->
  <VWE_VoidInscriptions.description>Оружие покрыто изменяющимися неевклидовыми глифами, нашёптывающими владельцу, которые шепчут владельцу, постоянно истощая его разум.</VWE_VoidInscriptions.description>
  <!-- EN: void -->
  <VWE_VoidInscriptions.traitAdjectives.0>пустотный</VWE_VoidInscriptions.traitAdjectives.0>
  <!-- EN: accursed -->
  <VWE_VoidInscriptions.traitAdjectives.1>проклятый</VWE_VoidInscriptions.traitAdjectives.1>
  <!-- EN: whispering -->
  <VWE_VoidInscriptions.traitAdjectives.2>шепчущий</VWE_VoidInscriptions.traitAdjectives.2>
  <!-- EN: maddening -->
  <VWE_VoidInscriptions.traitAdjectives.3>сводящий с ума</VWE_VoidInscriptions.traitAdjectives.3>
  <!-- EN: eldritch -->
  <VWE_VoidInscriptions.traitAdjectives.4>потусторонний</VWE_VoidInscriptions.traitAdjectives.4>
</LanguageData>