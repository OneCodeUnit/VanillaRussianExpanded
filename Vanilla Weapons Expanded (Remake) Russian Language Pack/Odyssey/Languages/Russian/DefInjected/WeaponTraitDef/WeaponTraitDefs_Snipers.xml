<?xml version="1.0" encoding="utf-8"?>
<LanguageData>
  <!-- EN: uranium slug -->
  <VWE_UraniumSlug.label>урановые снаряды</VWE_UraniumSlug.label>
  <!-- EN: This weapon fires ultra-dense uranium slugs, giving it immense armor-penetrating capabilities, though the heavy recoil increases the time between shots. -->
  <VWE_UraniumSlug.description>Оружие стреляет сверхплотными урановыми снарядами, обеспечивающими колоссальную бронебойность, но усилившаяся отдача увеличивает время между выстрелами.</VWE_UraniumSlug.description>
  <!-- EN: anti-tank -->
  <VWE_UraniumSlug.traitAdjectives.0>противотанковый</VWE_UraniumSlug.traitAdjectives.0>
  <!-- EN: slug -->
  <VWE_UraniumSlug.traitAdjectives.1>снарядный</VWE_UraniumSlug.traitAdjectives.1>
  <!-- EN: uranium -->
  <VWE_UraniumSlug.traitAdjectives.2>урановый</VWE_UraniumSlug.traitAdjectives.2>
  <!-- EN: dense -->
  <VWE_UraniumSlug.traitAdjectives.3>сверхплотный</VWE_UraniumSlug.traitAdjectives.3>

  <!-- EN: straight-pull action -->
  <VWE_StraightPullAction.label>прямой затвор</VWE_StraightPullAction.label>
  <!-- EN: This weapon uses a linear bolt mechanism to drastically reduce cooldown time, though it compromises long-range stability. -->
  <VWE_StraightPullAction.description>Оружие использует линейный механизм затвора, который резко сокращает время перезарядки ценой снижения точности для дальних дистанций.</VWE_StraightPullAction.description>
  <!-- EN: straight-pull -->
  <VWE_StraightPullAction.traitAdjectives.0>прямой затвор</VWE_StraightPullAction.traitAdjectives.0>
  <!-- EN: rapid-bolt -->
  <VWE_StraightPullAction.traitAdjectives.1>быстрый болт</VWE_StraightPullAction.traitAdjectives.1>
  <!-- EN: skirmisher -->
  <VWE_StraightPullAction.traitAdjectives.2>застрельщик</VWE_StraightPullAction.traitAdjectives.2>
  <!-- EN: fast-cycle -->
  <VWE_StraightPullAction.traitAdjectives.3>быстрый цикл</VWE_StraightPullAction.traitAdjectives.3>

  <!-- EN: acceleration rail -->
  <VWE_AccelerationRail.label>разгонный рельс</VWE_AccelerationRail.label>
  <!-- EN: Retrofitted with a pulse-charge rail system, this weapon fires a single, high-velocity energy bolt that drastically improves damage and armor penetration. -->
  <VWE_AccelerationRail.description>У оружия доработана энергетическая рельсовая система, которая позволяет стрелять одиночным высокоскоростным энергетическим болтом, значительно улучшающим урон и бронебойность.</VWE_AccelerationRail.description>
  <!-- EN: charged -->
  <VWE_AccelerationRail.traitAdjectives.0>заряженный</VWE_AccelerationRail.traitAdjectives.0>
  <!-- EN: pulse -->
  <VWE_AccelerationRail.traitAdjectives.1>импульсный</VWE_AccelerationRail.traitAdjectives.1>
  <!-- EN: rail-assisted -->
  <VWE_AccelerationRail.traitAdjectives.2>рельсовый</VWE_AccelerationRail.traitAdjectives.2>
  <!-- EN: retrofitted -->
  <VWE_AccelerationRail.traitAdjectives.3>модернизированный</VWE_AccelerationRail.traitAdjectives.3>
  <!-- EN: hybrid -->
  <VWE_AccelerationRail.traitAdjectives.4>гибридный</VWE_AccelerationRail.traitAdjectives.4>

  <!-- EN: canted iron sights -->
  <VWE_CantedIronSights.label>боковой прицел</VWE_CantedIronSights.label>
  <!-- EN: This weapon includes a secondary sight mounted at a 45-degree angle, allowing the sniper to effectively engage targets at close range without using the scope. -->
  <VWE_CantedIronSights.description>Оружие оснащено дополнительным прицелом, закреплённым под углом 45 градусов. Он позволяет снайперу эффективно поражать цели на близкой дистанции без использования оптики.</VWE_CantedIronSights.description>
  <!-- EN: canted -->
  <VWE_CantedIronSights.traitAdjectives.0>боковой</VWE_CantedIronSights.traitAdjectives.0>
  <!-- EN: CQB -->
  <VWE_CantedIronSights.traitAdjectives.1>ББ</VWE_CantedIronSights.traitAdjectives.1>
  <!-- EN: skirmish -->
  <VWE_CantedIronSights.traitAdjectives.2>стычка</VWE_CantedIronSights.traitAdjectives.2>
  <!-- EN: hybrid -->
  <VWE_CantedIronSights.traitAdjectives.3>гибридный</VWE_CantedIronSights.traitAdjectives.3>
  <!-- EN: tactical -->
  <VWE_CantedIronSights.traitAdjectives.4>тактический</VWE_CantedIronSights.traitAdjectives.4>

  <!-- EN: fixed tele-lens -->
  <VWE_FixedTeleLens.label>дальняя оптика</VWE_FixedTeleLens.label>
  <!-- EN: This weapon is fitted with extreme magnification optics that significantly extend effective range but render the weapon completely unable to target enemies within a large minimum radius. -->
  <VWE_FixedTeleLens.description>Оружие оснащено оптикой с экстремальным увеличением, которое значительно увеличивает дальность, но полностью лишает возможности поражать врагов в пределах большого минимального радиуса.</VWE_FixedTeleLens.description>
  <!-- EN: telescopic -->
  <VWE_FixedTeleLens.traitAdjectives.0>телескопический</VWE_FixedTeleLens.traitAdjectives.0>
  <!-- EN: fixed-zoom -->
  <VWE_FixedTeleLens.traitAdjectives.1>фиксированное увеличение</VWE_FixedTeleLens.traitAdjectives.1>
  <!-- EN: far-sighted -->
  <VWE_FixedTeleLens.traitAdjectives.2>дальнобойный</VWE_FixedTeleLens.traitAdjectives.2>
  <!-- EN: observatory -->
  <VWE_FixedTeleLens.traitAdjectives.3>обзорный</VWE_FixedTeleLens.traitAdjectives.3>
