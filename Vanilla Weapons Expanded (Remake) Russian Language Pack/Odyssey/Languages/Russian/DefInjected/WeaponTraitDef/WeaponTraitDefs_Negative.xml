  <!-- EN: unreliable -->
  <VWE_Janky.traitAdjectives.4>ненадёжный</VWE_Janky.traitAdjectives.4>
  <!-- EN: jamming -->
  <VWE_Janky.traitAdjectives.5>заклинивающий</VWE_Janky.traitAdjectives.5>
</LanguageData>